<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="UtilsPila" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="UtilsPilaDinamica">
				<Option output="../../libs/UtilsPilaDinamica" prefix_auto="1" extension_auto="1" />
				<Option working_dir="" />
				<Option object_output="obj/Debug" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-g" />
					<Add directory="../../includes" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../includes" />
				</ResourceCompiler>
			</Target>
			<Target title="UtilsPilaEstatica">
				<Option output="../../libs/UtilsPilaEstatica" prefix_auto="1" extension_auto="1" />
				<Option working_dir="" />
				<Option object_output="obj/Debug" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-O2" />
					<Add option="-Wall" />
					<Add option="-DPILA_ESTATICA=1" />
					<Add directory="../../includes" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../includes" />
				</ResourceCompiler>
				<Linker>
					<Add option="-s" />
					<Add option="-lPilaEstatica" />
					<Add directory="../../libs" />
				</Linker>
			</Target>
			<Target title="Test_Dinamico">
				<Option output="bin/Test/UtilsPilaDinamica" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Test" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Option use_console_runner="0" />
			</Target>
			<Target title="Test_Estatico">
				<Option output="bin/Test/UtilsPilaEstatica" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/test" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Option use_console_runner="0" />
			</Target>
		</Build>
		<Unit filename="main.c">
			<Option compilerVar="CC" />
			<Option target="UtilsPilaDinamica" />
			<Option target="UtilsPilaEstatica" />
		</Unit>
		<Extensions />
	</Project>
</CodeBlocks_project_file>
