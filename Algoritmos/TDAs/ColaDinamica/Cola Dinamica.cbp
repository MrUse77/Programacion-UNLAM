<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Cola Dinamica" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="../../libs/ColaDinamica" prefix_auto="1" extension_auto="1" />
				<Option working_dir="" />
				<Option object_output="obj/Debug/" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-g" />
					<Add directory="../../includes" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../includes" />
				</ResourceCompiler>
				<Linker>
					<Add directory="../../libs" />
				</Linker>
			</Target>
			<Target title="Test">
				<Option output="bin/Test/Cola Dinamica" prefix_auto="1" extension_auto="1" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-pedantic" />
					<Add option="-Wextra" />
					<Add option="-Wall" />
					<Add option="-g" />
					<Add directory="../../includes" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../includes" />
				</ResourceCompiler>
				<Linker>
					<Add option="-lColaDinamica" />
					<Add directory="../../libs" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
		</Compiler>
		<Unit filename="Test/test_cola.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="main.c">
			<Option compilerVar="CC" />
			<Option target="Debug" />
		</Unit>
		<Extensions />
	</Project>
</CodeBlocks_project_file>
