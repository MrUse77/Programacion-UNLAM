				<Option compiler="gcc" />
				<Compiler>
					<Add option="-g" />
					<Add directory="../../../TDAs/includes" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../../TDAs/includes" />
				</ResourceCompiler>
				<Linker>
					<Add option="-lPila" />
					<Add option="-lFecha" />
					<Add directory="../../../TDAs/libs" />
				</Linker>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/Ejercicio 3" prefix_auto="1" extension_auto="1" />
