<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="PilaCircular" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Linux">
				<Option output="../../libs/Linux/PilaCircular" prefix_auto="1" extension_auto="1" />
				<Option working_dir="" />
				<Option object_output="obj/Debug/" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-g" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../includes" />
				</ResourceCompiler>
			</Target>
			<Target title="Windows">
				<Option output="../../libs/Windows/PilaCircular" prefix_auto="1" extension_auto="1" />
				<Option working_dir="" />
				<Option object_output="obj/Debug/" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-g" />
					<Add option="-nostdinc -I/usr/x86_64-w64-mingw32/include -I/usr/lib/gcc/x86_64-w64-mingw32/16.1.0/include" />
					<Add directory="../../includes" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../includes" />
				</ResourceCompiler>
			</Target>
		</Build>
		<VirtualTargets>
			<Add alias="WyL" targets="Linux;Windows;" />
		</VirtualTargets>
		<Compiler>
			<Add directory="../../includes" />
		</Compiler>
		<ResourceCompiler>
			<Add directory="../../includes" />
		</ResourceCompiler>
		<Unit filename="Test/test_pila.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="main.c">
			<Option compilerVar="CC" />
		</Unit>
		<Extensions />
	</Project>
</CodeBlocks_project_file>
