				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-O2" />
					<Add directory="../../../TDAs" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../../TDAs" />
				</ResourceCompiler>
				<Linker>
					<Add option="-s" />
					<Add option="-lPila" />
					<Add directory="../../../TDAs" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
		</Compiler>
		<ResourceCompiler>
			<Add directory="../../../TDAs/" />
		</ResourceCompiler>
		<Linker>
			<Add option="-lPila" />
			<Add directory="../../../TDAs" />
		</Linker>
		<Unit filename="main.c">
