<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Pila Estatica" />
		<Option pch_mode="2" />
		<Option compiler="gcc" />
		<Build>
			<Target title="Debug">
				<Option output="../../libs/PilaEstatica/Linux/PilaEstatica" prefix_auto="1" extension_auto="1" />
				<Option working_dir="" />
				<Option object_output="obj/Debug/" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-g" />
					<Add option="-DPILA_ESTATICA=1" />
					<Add directory="../../includes" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../includes" />
				</ResourceCompiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/Pila" prefix_auto="1" extension_auto="1" />
				<Option working_dir="" />
				<Option object_output="obj/Release/" />
				<Option type="2" />
				<Option compiler="gcc" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
			<Target title="Test">
				<Option output="bin/Test/TestPila" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Test/" />
				<Option type="1" />
				<Option compiler="gcc" />
				<Compiler>
					<Add option="-Wall" />
					<Add option="-g" />
					<Add option="-DPILA_ESTATICA=1" />
					<Add directory="../../includes" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../includes" />
				</ResourceCompiler>
				<Linker>
					<Add option="-lPilaEstatica" />
					<Add directory="../../libs" />
				</Linker>
			</Target>
			<Target title="Windows">
				<Option output="../../libs/PilaEstatica/Windows/PilaEstatica" prefix_auto="1" extension_auto="1" />
				<Option working_dir="" />
				<Option type="2" />
				<Option compiler="mingw-w64_windows_cross-compiler" />
				<Option createDefFile="1" />
				<Compiler>
					<Add option="-DPILA_ESTATICA=1" />
					<Add directory="../../includes" />
				</Compiler>
				<ResourceCompiler>
					<Add directory="../../includes" />
				</ResourceCompiler>
			</Target>
		</Build>
		<Unit filename="Pila.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="Test/test_pila.c">
			<Option compilerVar="CC" />
			<Option target="Test" />
		</Unit>
		<Extensions />
	</Project>
</CodeBlocks_project_file>
